pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: title
    elementType: text
    bounds: [60, 35, 700, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>25 REST APIs Across 6 Domains</strong></p>
  - elementId: title-line
    elementType: shape
    bounds: [60, 85, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: api-table
    elementType: table
    bounds: [60, 110, 1160, 400]
    columnWidths: [0.17, 0.33, 0.12, 0.12, 0.26]
    rowHeights: [0.11, 0.1113, 0.1113, 0.1113, 0.1113, 0.1113, 0.1113, 0.1113, 0.1111]
    style: "$default"
    rows:
      - - content: {text: "Domain", fontSize: 15}
        - content: {text: "Endpoint", fontSize: 15}
        - content: {text: "Method", fontSize: 15}
        - content: {text: "Auth", fontSize: 15}
        - content: {text: "Description", fontSize: 15}
      - - content:
            text: |
              <p>Auth (5)</p>
            fontSize: 14
          rowSpan: 2
        - content:
            text: |
              <p>/api/auth/register</p>
            fontSize: 14
        - content:
            text: |
              <p>POST</p>
            fontSize: 14
        - content:
            text: |
              <p>Public</p>
            fontSize: 14
        - content:
            text: |
              <p>Create new account</p>
            fontSize: 14
      - - content:
            text: |
              <p>/api/auth/login</p>
            fontSize: 14
        - content:
            text: |
              <p>POST</p>
            fontSize: 14
        - content:
            text: |
              <p>Public</p>
            fontSize: 14
        - content:
            text: |
              <p>Login with credentials</p>
            fontSize: 14
      - - content:
            text: |
              <p>Jobs (6)</p>
            fontSize: 14
          rowSpan: 2
        - content:
            text: |
              <p>/api/jobs</p>
            fontSize: 14
        - content:
            text: |
              <p>GET/POST</p>
            fontSize: 14
        - content:
            text: |
              <p>Any/Rec</p>
            fontSize: 14
        - content:
            text: |
              <p>List / Create jobs</p>
            fontSize: 14
      - - content:
            text: |
              <p>/api/jobs/:id</p>
            fontSize: 14
        - content:
            text: |
              <p>GET/PUT/DEL</p>
            fontSize: 14
        - content:
            text: |
              <p>Any/Rec</p>
            fontSize: 14
        - content:
            text: |
              <p>CRUD operations</p>
            fontSize: 14
      - - content:
            text: |
              <p>Applications (5)</p>
            fontSize: 14
          rowSpan: 2
        - content:
            text: |
              <p>/api/applications</p>
            fontSize: 14
        - content:
            text: |
              <p>GET/POST</p>
            fontSize: 14
        - content:
            text: |
              <p>Any/App</p>
            fontSize: 14
        - content:
            text: |
              <p>List / Submit application</p>
            fontSize: 14
      - - content:
            text: |
              <p>/api/applications/:id</p>
            fontSize: 14
        - content:
            text: |
              <p>GET/PUT</p>
            fontSize: 14
        - content:
            text: |
              <p>Any/Rec</p>
            fontSize: 14
        - content:
            text: |
              <p>Details / Update status</p>
            fontSize: 14
      - - content:
            text: |
              <p>AI (4)</p>
            fontSize: 14
        - content:
            text: |
              <p>/api/ai/analyze, /api/ai/rank</p>
            fontSize: 14
        - content:
            text: |
              <p>POST/GET</p>
            fontSize: 14
        - content:
            text: |
              <p>Recruiter</p>
            fontSize: 14
        - content:
            text: |
              <p>Trigger analysis / Get ranking</p>
            fontSize: 14
      - - content:
            text: |
              <p>Resume (3)</p>
            fontSize: 14
        - content:
            text: |
              <p>/api/resumes/upload</p>
            fontSize: 14
        - content:
            text: |
              <p>POST</p>
            fontSize: 14
        - content:
            text: |
              <p>Applicant</p>
            fontSize: 14
        - content:
            text: |
              <p>Upload resume PDF</p>
            fontSize: 14
  - elementId: note
    elementType: text
    bounds: [60, 530, 1160, 40]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      lineHeight: 1.4
      align: [left, top]
      text: |
        <p>Plus Notification APIs (/api/notifications) and Email APIs (/api/emails). All endpoints follow REST conventions with consistent error responses.</p>