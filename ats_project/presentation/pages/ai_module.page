pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: title
    elementType: text
    bounds: [60, 35, 800, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>AI Scoring Engine: Weighted Algorithm</strong></p>
  - elementId: title-line
    elementType: shape
    bounds: [60, 85, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: w1-bg
    elementType: shape
    bounds: [60, 120, 270, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border:
      style: solid
      width: 1
      color: "$light"
  - elementId: w1-pct
    elementType: text
    bounds: [60, 130, 270, 60]
    content:
      fontSize: 44
      color: "$accent"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>40%</strong></p>
