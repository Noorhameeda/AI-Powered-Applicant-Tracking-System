pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  - elementId: title
    elementType: text
    bounds: [60, 40, 400, 50]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>AGENDA</strong></p>
  - elementId: title-line
    elementType: shape
    bounds: [60, 95, 80, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: ch1-num
    elementType: text
    bounds: [80, 160, 100, 70]
    content:
      fontSize: 56
      color: "$accent"
      fontFamily: "Liter"
      align: [left, top]
      wrap: false
      text: |
        <p><strong>01</strong></p>
  - elementId: ch1-title
    elementType: text
    bounds: [180, 165, 400, 35]
    content:
      fontSize: 24
      color: "$primary"
      fontFamily: "Liter"
      align: [left, top]
      wrap: false
      text: |
        <p><strong>Project Overview</strong></p>
  - elementId: ch1-desc
    elementType: text
    bounds: [180, 205, 400, 28]
    content:
      fontSize: 16
      color: "$secondary"
      fontFamily: "Liter"
      align: [left, top]
      wrap: false
      text: |
        <p>Business problem, solution, system goals</p>
  - elementId: ch1-line
    elementType: shape
    bounds: [80, 260, 520, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$light"
  - elementId: ch2-num
