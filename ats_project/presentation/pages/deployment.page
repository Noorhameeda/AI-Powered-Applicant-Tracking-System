pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: title
    elementType: text
    bounds: [60, 35, 900, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Deployed on Vercel + Render + MongoDB Atlas</strong></p>
  - elementId: title-line
    elementType: shape
    bounds: [60, 85, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: c1-bg
    elementType: shape
    bounds: [60, 120, 370, 220]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border:
      style: solid
      width: 1
      color: "$light"
  - elementId: c1-icon
    elementType: icon
    bounds: [80, 140, 40, 40]
    iconName: "fas:globe"
    fill:
      type: solid
      color: "$primary"
  - elementId: c1-title
    elementType: text
    bounds: [130, 140, 280, 30]
    content:
      fontSize: 20
      color: "$primary"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Frontend</strong></p>
  - elementId: c1-body
    elementType: text
    bounds: [80, 190, 330, 130]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p><span style="color:$accent;">&#9632;</span> Vercel Edge Network</p>
        <p><span style="color:$accent;">&#9632;</span> Global CDN</p>
        <p><span style="color:$accent;">&#9632;</span> Auto-deploy on push</p>
        <p><span style="color:$accent;">&#9632;</span> Preview deployments</p>
  - elementId: c2-bg
