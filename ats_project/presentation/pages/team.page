pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: title
    elementType: text
    bounds: [60, 35, 800, 45]
    content:
      style: "$title"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>5 Developers, 4 Domains, 28 Days</strong></p>
  - elementId: title-line
    elementType: shape
    bounds: [60, 85, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: d1-bg
    elementType: shape
    bounds: [60, 120, 560, 120]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border:
      style: solid
      width: 1
      color: "$light"
  - elementId: d1-icon
    elementType: icon
    bounds: [80, 140, 36, 36]
    iconName: "fas:lock"
    fill:
      type: solid
      color: "$primary"
  - elementId: d1-title
    elementType: text
    bounds: [130, 135, 300, 28]
    content:
      fontSize: 20
      color: "$primary"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Dev 1: Auth &amp; Security</strong></p>
  - elementId: d1-body
    elementType: text
    bounds: [130, 168, 470, 60]
    content:
      fontSize: 14
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>JWT authentication, RBAC middleware, bcrypt hashing, Helmet.js, rate limiting, input validation, XSS protection</p>
  - elementId: d2-bg
    elementType: shape
    bounds: [660, 120, 560, 120]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border:
      style: solid
      width: 1
      color: "$light"
